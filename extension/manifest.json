{
  "manifest_version": 3,
  "name": "GreatFrontend Sync",
  "version": "0.1.0",
  "description": "Automatically sync completed GreatFrontend solutions to a private GitHub repository.",
  "permissions": ["storage", "identity", "scripting"],
  "host_permissions": ["https://www.greatfrontend.com/*", "https://api.github.com/*"],
  "background": {
    "service_worker": "background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.greatfrontend.com/*"],
      "js": ["content/index.ts"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "icons": {
    "16": "popup/assets/logo.png",
    "48": "popup/assets/logo.png",
    "128": "popup/assets/logo.png"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "GreatFrontend Sync",
    "default_icon": {
      "16": "popup/assets/logo.png",
      "48": "popup/assets/logo.png",
      "128": "popup/assets/logo.png"
    }
  },
  "options_page": "options/index.html",
  "web_accessible_resources": [
    {
      "resources": ["injected.js", "assets/*.js"],
      "matches": ["https://www.greatfrontend.com/*"]
    }
  ]
}
